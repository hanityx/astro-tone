---
import { getCollection } from 'astro:content';
import Layout from '../components/layout/Layout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Home">
  <section class="mb-10">
    <h1 class="text-4xl font-bold text-slate-100">Latest Posts</h1>
    <p class="mt-3 text-slate-400">Clean and simple starter for your first public commit.</p>
  </section>

  <section class="grid gap-4">
    {posts.map((post) => (
      <article class="rounded-xl border border-slate-800 bg-slate-900/40 p-5">
        <a href={`/posts/${post.slug}`} class="block">
          <h2 class="text-2xl font-semibold text-slate-100">{post.data.title}</h2>
          <p class="mt-2 text-sm text-slate-400">{post.data.summary}</p>
          <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-slate-500">
            <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString()}</time>
            {(post.data.tags || []).map((tag) => (
              <span class="rounded border border-slate-700 px-2 py-0.5">{tag}</span>
            ))}
          </div>
        </a>
      </article>
    ))}
  </section>
</Layout>
